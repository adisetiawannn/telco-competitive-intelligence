# =============================================================
# telco-competitive-intelligence — Template .env
# =============================================================
# Salin file ini menjadi .env dan isi nilai yang sesuai.
# cp .env.example .env

# Project
PROJECT_NAME=telco-competitive-intelligence
ENVIRONMENT=development

# Paths
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_EXTERNAL_DIR=data/external
OUTPUT_DIR=outputs
MODELS_DIR=src/models

# Logging
LOG_LEVEL=INFO

# API Keys (isi jika dibutuhkan)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# HUGGINGFACE_TOKEN=

# Database (isi jika dibutuhkan)
# DATABASE_URL=

# Web Scraping (isi jika dibutuhkan)
# USER_AGENT=
# PROXY_URL=
