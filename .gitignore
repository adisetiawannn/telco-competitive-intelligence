# ============================================================
# TELCO COMPETITIVE INTELLIGENCE — .gitignore
# ============================================================

# ── Credentials & secrets ───────────────────────────────────
.env
.env.local
.env.*.local

# ── Python environment ──────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Python artifacts ────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Jupyter ─────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_meta

# ── Database & data files ───────────────────────────────────
*.db
*.sqlite
*.sqlite3
data/raw/
data/processed/
data/external/
data/articles_backup_*.db

# ── Config files dengan intelligence ────────────────────────
configs/rss_feeds.yaml

# ── Output & model files ────────────────────────────────────
outputs/
*.pkl
*.h5
*.model
*.pt
*.pth

# ── Log files ───────────────────────────────────────────────
*.log
logs/

# ── OS files ────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
._*

# ── IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swn

# ── Testing ─────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── models & data ─────────────────────────────────────────────
echo "models/"
echo "data/training_data.db"